#!/bin/bash
mkdir -p models slow_models

tail -n +2 models.csv | while IFS=',' read -r id repo hf_ctx applied_ctx type; do
    repo_id="${repo%%:*}"
    quant="${repo##*:}"

    reponame="${repo_id##*/}"

    # Derive the expected filename from the repo name
    # e.g., amoral-gemma3-27B-v2-qat-GGUF -> amoral-gemma3-27B-v2-qat
    basename="${reponame%-GGUF}"
    expected_filename="${basename}.${quant}.gguf"

    # Determine target directory based on type column
    target_dir="models"
    case "$type" in
        *slow*) target_dir="slow_models" ;;
    esac

    echo "Processing $repo_id ($quant) → $target_dir/"

    # Check if the target file already exists in either location
    if [ -f "models/$expected_filename" ] || [ -f "slow_models/$expected_filename" ]; then
        echo "SKIP: File already exists → $expected_filename"
        continue
    else
        echo "File not found: $expected_filename. Proceeding to download."
    fi

    pattern="*${quant}.gguf"

    echo "Downloading $repo_id (quant: $quant) → $target_dir/"

    hf download "$repo_id" \
        --include "$pattern" \
        --local-dir "$target_dir"

done